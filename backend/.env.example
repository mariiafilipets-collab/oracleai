# Backend .env — copy to .env and fill values
# See docs/AI-MODELS-RECOMMENDATIONS.md for model presets

# ═══ Server ═══
PORT=3001
DEPLOYMENT_NETWORK=localhost

# ═══ Blockchain ═══
RPC_URL=https://bsc-testnet-rpc.publicnode.com
RPC_FALLBACK_URL=https://bsc-testnet.bnbchain.org
CENTRAL_WALLET=
DEPLOYER_PRIVATE_KEY=

# ═══ Security ═══
# Required admin API key — admin endpoints are disabled if not set
ADMIN_API_KEY=
# CORS allowed origins (comma-separated; empty = allow all — dev only)
CORS_ORIGINS=https://oracleai-predict.app,https://www.oracleai-predict.app

# ═══ DB ═══
MONGODB_URI=mongodb://localhost:27017/oracleai

# ═══ AI (OpenRouter) — для генерации событий нужен openrouter ═══
AI_PROVIDER=openrouter
OPENROUTER_API_KEY=sk-or-v1-...

# Модели (опционально; без них используются дефолты)
OPENROUTER_RETRIEVER_MODEL=perplexity/sonar-pro
OPENROUTER_NORMALIZER_MODEL=google/gemini-2.0-flash-001
OPENROUTER_FORMATTER_MODEL=
OPENROUTER_ARBITER_MODEL=google/gemini-2.0-flash-001
OPENROUTER_SEARCH_MODEL=x-ai/grok-4.1-fast
OPENROUTER_RESOLVE_MODEL=x-ai/grok-4.1-fast
OPENROUTER_FALLBACK_MODEL=google/gemini-2.0-flash-001

# ═══ Optional ═══
ENABLE_SCHEDULER=true
ENABLE_EVENT_POLLING=true
EVENT_CATCHUP_MAX_GAP=5000
BETTERSTACK_SOURCE_TOKEN=
TGE_START_AT=TBA
